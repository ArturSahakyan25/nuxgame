{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "schematics": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "projects": {
    "Affilate-Nuxgame": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "i18n": {
        "sourceLocale": "en",
        "locales": {
          "ru": "src/locale/messages.ru.xlf",
          "es": "src/locale/messages.es.xlf",
          "pt": "src/locale/messages.pt.xlf"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "./"
              }
            ],
            "styles": [
              "src/tailwind.css",
              "public/styles/scss/style.scss",
              "src/styles.scss"
            ],
            "polyfills": [
              "@angular/localize/init"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "all",
              "localize": true
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "ru": {
              "localize": [
                "ru"
              ]
            },
            "en": {
              "localize": [
                "en"
              ]
            },
            "es": {
              "localize": [
                "es"
              ]
            },
            "pt": {
              "localize": [
                "pt"
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "Affilate-Nuxgame:build:production"
            },
            "development": {
              "buildTarget": "Affilate-Nuxgame:build:development"
            },
            "ru": {
              "buildTarget": "Affilate-Nuxgame:build:development,ru"
            },
            "en": {
              "buildTarget": "Affilate-Nuxgame:build:development,en"
            },
            "es": {
              "buildTarget": "Affilate-Nuxgame:build:development,es"
            },
            "pt": {
              "buildTarget": "Affilate-Nuxgame:build:development,pt"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}